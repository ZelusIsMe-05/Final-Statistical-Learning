# Copy this file to .env and fill in the tunnel URLs.

# Colab model server URL for summarization and retrieval.
# Example: COLAB_API_URL=https://abcdef.a.pinggy.io
COLAB_API_URL=http://localhost:8001

# Ollama refine server URL for turning retrieved context into final answers.
# Leave this empty if Ollama is not running.
# Example: OLLAMA_REFINE_URL=https://ghijkl.a.pinggy.io
OLLAMA_REFINE_URL=http://localhost:11434

# Local backend port.
BACKEND_PORT=8000
